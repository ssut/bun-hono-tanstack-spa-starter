{
  "name": "bun-hono-tanstack-spa-starter",
  "module": "src/server/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:all": "bun run --parallel dev dev:web",
    "dev": "bun --hot src/server/index.ts | pino-pretty",
    "dev:web": "bunx vite --config vite.config.ts",
    "build:web": "bunx vite build --config vite.config.ts",
    "start": "bun src/server/index.ts",
    "worker": "bun src/worker/worker.ts",
    "migrate": "bun src/server/db/migrate.ts",
    "typecheck": "bunx tsgo --noEmit -p tsconfig.web.json && bunx tsgo --noEmit -p tsconfig.server.json",
    "lint": "bunx biome check --write --diagnostic-level=error ./src",
    "check": "bun run lint && bun run typecheck",
    "test": "bun test",
    "shadcn": "TS_NODE_PROJECT=tsconfig.web.json bunx shadcn"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/react-router-devtools": "^1.163.2",
    "@tanstack/router-plugin": "^1.163.2",
    "@types/bun": "latest",
    "@types/node": "^25.3.1",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "8.0.0-beta.14",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@t3-oss/env-core": "^0.13.10",
    "hono": "^4.12.2",
    "hono-pino": "^0.10.3",
    "kysely": "^0.28.11",
    "kysely-ctl": "^0.20.0",
    "kysely-migration-cli": "^0.4.2",
    "kysely-postgres-js": "^3.0.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  }
}
